# Same Supabase project the iOS app uses. Both values are public/anon-scoped, safe to
# expose client-side (NEXT_PUBLIC_ prefix is required for that reason).
NEXT_PUBLIC_SUPABASE_URL=https://ipfzswswwukfqphloojo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_KvH6r2_haPL1sbAc1d4F-Q_5l1ImkpK

# Where auth callbacks redirect back to in dev. Must also be added to the Supabase
# project's Auth -> URL Configuration -> Additional Redirect URLs as
# http://localhost:3000/auth/callback.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS (marketing copy: hero text, feature copy, FAQ entries, legal page bodies).
# Project ID is public/non-secret by design — reads go straight to Sanity's CDN API,
# no token needed, as long as the "production" dataset is Public and this app's origin
# is allowed under Sanity project settings -> API -> CORS origins. Studio itself is
# embedded at /studio (src/sanity/) — sign-in there is a real Sanity account, separate
# from this app's own Supabase auth.
NEXT_PUBLIC_SANITY_PROJECT_ID=fck477cu
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sent by the Studio's custom FAQ tool (src/sanity/tools/FaqTool.tsx) as the x-admin-secret
# header when writing to the faq_entries table (via the admin-faq Supabase Edge Function) — FAQ
# content there is the single source for both the marketing site's /faq page and the iOS app's
# Settings > Support screen. Deliberately NEXT_PUBLIC_ (client-exposed): the Studio tool runs in
# the browser and has no other way to authenticate; see admin-faq/index.ts's doc comment for the
# security reasoning. Must match the `FAQ_ADMIN_SECRET` Supabase secret exactly (not committed
# here — a real per-environment value, unlike the public Sanity/Supabase config above).
NEXT_PUBLIC_FAQ_ADMIN_SECRET=

# RevenueCat Web Billing (RevenueCat Billing, powered by Stripe) public key — from the
# RevenueCat dashboard -> Project settings -> API keys -> "Web Billing" public key.
# Safe to expose client-side, same trust model as the app's RevenueCat public SDK key.
# The value previously hardcoded in the old static site (strp_sb_...) looked like a
# sandbox/test key — confirm/rotate for production before go-live.
NEXT_PUBLIC_REVENUECAT_WEB_BILLING_API_KEY=

# Android waitlist confirmation emails (app/api/waitlist/route.ts) — server-only
# (no NEXT_PUBLIC_ prefix), same Resend account the old Cloudflare Function used.
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=Twofold <hello@twofoldapp.com.au>
WAITLIST_NOTIFY_EMAIL=hello@twofoldapp.com.au
