{
  "name": "twofold-site",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler pages dev . --d1=DB=twofold-waitlist",
    "deploy": "wrangler pages deploy .",
    "db:migrate:local": "wrangler d1 execute twofold-waitlist --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute twofold-waitlist --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "typescript": "^5.5.4",
    "wrangler": "^4.4.0"
  }
}
